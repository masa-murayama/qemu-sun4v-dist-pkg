SHAR_EOF
${echo} bunzipping file adddrv2.sh &&

bzip2 -dkc ${lock_dir}/bzi > 'adddrv2.sh' && \
  (set 20 25 01 31 00 32 58 'adddrv2.sh'
   eval "${shar_touch}") && \
  chmod 0644 'adddrv2.sh'
if test $? -ne 0
then ${echo} "restore of adddrv2.sh failed"
fi
test `LC_ALL=C wc -c < 'adddrv2.sh'` -ne 860 && \
  ${echo} "restoration warning:  size of 'adddrv2.sh' is not 860"
fi
if rm -fr ${lock_dir}
then ${echo} "x - removed lock directory ${lock_dir}."
else ${echo} "x - failed to remove lock directory ${lock_dir}."
     exit 1
fi
exit 0
