SHAR_EOF
${echo} bunzipping file hsimd &&

bzip2 -dkc ${lock_dir}/bzi > 'hsimd' && \
  (set 20 25 01 28 01 13 03 'hsimd'
   eval "${shar_touch}") && \
  chmod 0644 'hsimd'
if test $? -ne 0
then ${echo} "restore of hsimd failed"
fi
test `LC_ALL=C wc -c < 'hsimd'` -ne 35048 && \
  ${echo} "restoration warning:  size of 'hsimd' is not 35048"
fi
# ============= adddrv_a.sh ==============
if test -n "${keep_file}" && test -f 'adddrv_a.sh'
then
${echo} "x - SKIPPING adddrv_a.sh (file already exists)"

else
${echo} "x - extracting adddrv_a.sh bzipped"
  sed 's/^X//' << 'SHAR_EOF' | uudecode &&
